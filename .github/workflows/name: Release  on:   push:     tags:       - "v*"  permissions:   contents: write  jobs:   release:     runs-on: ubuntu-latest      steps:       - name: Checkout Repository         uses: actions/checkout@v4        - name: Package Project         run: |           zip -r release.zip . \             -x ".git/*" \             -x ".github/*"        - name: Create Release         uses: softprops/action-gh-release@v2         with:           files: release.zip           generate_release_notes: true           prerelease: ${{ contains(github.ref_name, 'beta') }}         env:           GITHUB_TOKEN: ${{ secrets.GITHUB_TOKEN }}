const FREE_LIMIT = 50;

let testsUsed =
parseInt(localStorage.getItem("testsUsed")) || 0;

updateUI();

function updateUI() {

    document.getElementById("used").textContent =
        testsUsed;

    document.getElementById("remaining").textContent =
        Math.max(0, FREE_LIMIT - testsUsed);
}

function runTest() {

    const message =
        document.getElementById("message");

    if (testsUsed >= FREE_LIMIT) {

        message.className = "error";

        message.innerHTML = `
            <h3>Access Blocked</h3>
            <p>Free limit reached.</p>
            <p>Please upgrade to continue.</p>
        `;

        return;
    }

    testsUsed++;

    localStorage.setItem(
        "testsUsed",
        testsUsed
    );

    updateUI();

    message.className = "success";

    message.innerHTML = `
        ✔ Test #${testsUsed} completed successfully
    `;
}

function resetTests() {

    if (!confirm("Reset test counter?"))
        return;

    testsUsed = 0;

    localStorage.setItem(
        "testsUsed",
        0
    );

    updateUI();

    document.getElementById(
        "message"
    ).innerHTML = "";

}

function exportData() {

    const data = {
        testsUsed: testsUsed,
        remaining:
            FREE_LIMIT - testsUsed,
        date:
            new Date().toISOString()
    };

    const json =
        JSON.stringify(data, null, 2);

    navigator.clipboard
        .writeText(json)
        .then(() => {
            alert("Data copied!");
        });
}

setInterval(() => {

    const now = new Date();

    const time =
        now.toLocaleTimeString();

    const clock =
        document.getElementById("clock");

    if (clock) {
        clock.textContent = time;
    }

}, 1000);
