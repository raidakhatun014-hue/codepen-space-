*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#0f1117;
    color:#00ff88;
    font-family:'Segoe UI',sans-serif;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:20px;
}

.container{
    width:100%;
    max-width:550px;
    background:#161b22;
    border:1px solid #30363d;
    border-radius:16px;
    padding:30px;
    box-shadow:0 0 25px rgba(0,255,136,.15);
}

h1{
    text-align:center;
    margin-bottom:25px;
    color:#00ff88;
}

.stat{
    background:#0d1117;
    border:1px solid #30363d;
    padding:15px;
    border-radius:10px;
    margin-bottom:12px;
    font-size:18px;
}

button{
    width:100%;
    padding:14px;
    border:none;
    border-radius:10px;
    background:#00ff88;
    color:#000;
    font-size:16px;
    font-weight:bold;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    transform:translateY(-2px);
    background:#00d973;
    box-shadow:0 0 15px rgba(0,255,136,.4);
}

.notice{
    margin-top:20px;
    text-align:center;
    color:#ffd700;
    font-size:14px;
}

.error{
    margin-top:20px;
    text-align:center;
    color:#ff4444;
    font-weight:bold;
}

.success{
    margin-top:20px;
    text-align:center;
    color:#00ff88;
    font-weight:bold;
}

.card{
    background:#0d1117;
    border:1px solid #30363d;
    border-radius:12px;
    padding:15px;
    margin-top:15px;
}

@media(max-width:600px){

.container{
    padding:20px;
}

h1{
    font-size:24px;
}

.stat{
    font-size:16px;
}

button{
    font-size:15px;
}

}
